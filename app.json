{
  "expo": {
    "name": "STEMM",
    "slug": "STEMM",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "stemm",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      "expo-font",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow STEMM to access the microphone to measure sound levels."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow STEMM to access your photos to attach experiment videos.",
          "cameraPermission": "Allow STEMM to use the camera to record experiment videos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow STEMM to access your GPS coordinates to display your activity location on the interactive map."
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "Allow STEMM to record accelerometer data to measure structural integrity under simulated seismic forces."
        }
      ],
      "expo-notifications",
      "expo-task-manager",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
